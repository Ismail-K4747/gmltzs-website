---
// Icon library — original inline SVGs from the legacy index.html.
// Keyed by the value/about-card title so the layout stays identical
// while the CMS-driven content (titles, descriptions) remains editable.

interface Props {
  name: string;
  size?: number;
}
const { name, size = 32 } = Astro.props;

const ICONS: Record<string, string> = {
  // About cards
  'Trusted & Established': `<path d="M6 9H4.5a2.5 2.5 0 0 1 0-5C7 4 7 7 7 7"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5C17 4 17 7 17 7"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/>`,
  'Client-First': `<path d="M20.42 4.58a5.4 5.4 0 0 0-7.65 0l-.77.78-.77-.78a5.4 5.4 0 0 0-7.65 0C1.46 6.7 1.33 10.28 4 13l8 8 8-8c2.67-2.72 2.54-6.3.42-8.42z"/>`,
