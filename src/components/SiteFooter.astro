---
import { getEntry } from 'astro:content';
const siteEntry = await getEntry('settings', 'site');
const site = siteEntry?.data;
const year = new Date().getFullYear();
---
<footer class="footer">
  <div class="container">
    <div class="footer__top">
      <div class="footer__brand">
        <a href="/" class="nav__logo">
          <span class="nav__logo-icon">GM</span>
          <span class="nav__logo-text">Group</span>
        </a>
        <p class="footer__tagline" set:html={(site?.footerTagline ?? '').replace(/\n/g, '<br />')}></p>
      </div>
      <div class="footer__links">
        <div class="footer__col">
          <h4>Company</h4>
          <ul>
            <li><a href="/#about">About Us</a></li>
            <li><a href="/#values">Our Values</a></li>
            <li><a href="/insights.html">Insights</a></li>
            <li><a href="/#testimonials">Testimonials</a></li>
            <li><a href="/#contact">Contact</a></li>
          </ul>
        </div>
        <div class="footer__col">
          <h4>Businesses</h4>
          <ul>
            <li><a href="/businesses/medical-devices.html">Medical Devices</a></li>
            <li><a href="/businesses/real-estate.html">Real Estate</a></li>
            <li><a href="/businesses/medics.html">Pharmacy</a></li>
            <li><a href="/businesses/laboratory.html">Laboratory</a></li>
          </ul>
        </div>
        <div class="footer__col">
          <h4>Contact</h4>
          <ul>
            {site?.contactPhone && <li><a href={`tel:${site.contactPhone}`}>{site.contactPhone}</a></li>}
            {site?.contactEmail && <li><a href={`mailto:${site.contactEmail}`}>{site.contactEmail}</a></li>}
          </ul>
        </div>
        <div class="footer__col">
          <h4>Legal</h4>
          <ul>
            <li><a href="/terms.html">Terms of Use</a></li>
            <li><a href="/privacy.html">Privacy Policy</a></li>
          </ul>
        </div>
      </div>
    </div>
    <div class="footer__bottom">
      <p>{site?.footerLegal?.replace('2026', String(year)) ?? `© ${year} General Malick Limited. All rights reserved.`}</p>
    </div>
  </div>
</footer>
